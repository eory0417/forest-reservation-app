{
  "name": "forest-reservation-app",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.60.0"
  },
  "description": "전국 휴양림 실시간 최저가 및 경로 조회기",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.15.2"
  },
  "build": {
    "productName": "휴양림최저가조회기",
    "appId": "com.forest.reservation",
    "win": {
      "target": [
        "portable"
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/playwright",
      "node_modules/playwright-core"
    ]
  }
}
